<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>phone_or_email_not_be_empty</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
ISBLANK( Phone__c ),
ISBLANK( Email__c )
)</errorConditionFormula>
    <errorMessage>Please enter either a phone number or an email address.</errorMessage>
</ValidationRule>
