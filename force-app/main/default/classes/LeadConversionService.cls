    /**
    * @description - method to convert lead
    * @return responselist
    */
    @HttpPost
    global static String convertLead() {
        //RestRequest
        RestRequest request = RestContext.request;
        //RestResponse
        //RestResponse response = RestContext.response;
        //list of map of response lists
        List<Map<String, Object>> responseList = new List<Map<String, Object>>();

        try {
            //String of request body payload
            String payload = request.requestBody.toString();
            //System.debug('137 Payload received: ' + payload);

            // Deserialize the payload as a list of objects
            Object payloadObj = JSON.deserializeUntyped(payload);

            // Check if the payload is a list or a map
            if (payloadObj instanceof List<Object>) {
                // Handle bulk records (list of maps)
                for (Object recordObj : (List<Object>) payloadObj) {
                    //Map of payload map
                    Map<String, Object> payloadMap = (Map<String, Object>) recordObj;
                    responseList.add(processSingleLead(payloadMap));
                    //system.debug('148 responseList----'+responseList);
                }
            } else if (payloadObj instanceof Map<String, Object>) {
                // Handle single record (map)
                Map<String, Object> payloadMap = (Map<String, Object>) payloadObj;
                responseList.add(processSingleLead(payloadMap));
                //system.debug('154 responseList----'+responseList);

            } else {
                throw new AuraHandledException('Invalid payload format.');
            }

            return JSON.serialize(responseList);
        } catch (Exception e) {
            Map<String, Object> errorResponse = new Map<String, Object>();
            errorResponse.put('message', 'Error: ' + e.getMessage());
            //System.debug('161 Exception occurred: ' + e.getMessage());
            responseList.add(errorResponse);
            return JSON.serialize(responseList);
        }
    }

