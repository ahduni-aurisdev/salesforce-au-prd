    * @param records  list of records to be updated
    * @param personAccountId Account Id to be updated
    * @param recordsToUpdate list of records to be updated
    * Method Name : updateRecordsWithPersonAccountId
    */
    public static void updateRecordsWithPersonAccountId(List<SObject> records, Id personAccountId, List<SObject> recordsToUpdate) {
        for (SObject record : records) {
            record.put('Account__c', personAccountId); // Replace with the correct API name of the field
            recordsToUpdate.add(record);
        }
    }

    /**
    * created By - Rishav
    * @description - Method to map Executive Education specific fields from Lead to Opportunity
    * @param lead - Source Lead record
    * @param opportunity - Target Opportunity record
    * @param accountId - Account Id for reference
    */
    public static void mapExecutiveEducationFields(Lead lead, Opportunity opportunity, Id accountId) {
        try {
            System.debug('Starting Executive Education field mapping for Lead: ' + lead.Id);
            
            // Check if this is an Executive Education record type
            // Adjust the record type name based on your Salesforce configuration
            if (lead.RecordType.DeveloperName != 'Executive_Education' && 
                lead.RecordType.DeveloperName != 'Executive_Education_Lead') {
                System.debug('Not an Executive Education Lead. Skipping Executive Education mapping.');
                return;
            }
            
            System.debug('Processing Executive Education Lead: ' + lead.Id);
            
            // 1. Map Account Name (AccountId)
            if (accountId != null && opportunity.AccountId == null) {
                opportunity.AccountId = accountId;
                System.debug('Mapped AccountId: ' + accountId);
            }
            
            // 2. Map Registration_Date__c
            if (lead.Registration_Date__c != null) {
                opportunity.Registration_Date__c = lead.Registration_Date__c;
                System.debug('Mapped Registration_Date__c: ' + lead.Registration_Date__c);
            }
            
            // 3. Map Application_Initiated_Date__c
            if (lead.Application_Date__c != null) {
                opportunity.Application_Initiated_Date__c = lead.Application_Date__c;
                System.debug('Mapped Application_Initiated_Date__c: ' + lead.Application_Date__c);
            } else if (lead.Registration_Date__c != null) {
                // Fallback to Registration Date if Application Date is not available
                opportunity.Application_Initiated_Date__c = lead.Registration_Date__c;
                System.debug('Mapped Application_Initiated_Date__c (from Registration Date): ' + lead.Registration_Date__c);
            }
            
            // 4. Map Application_Number__c
            if (lead.Application_Number__c != null) {
                opportunity.Application_Number__c = lead.Application_Number__c;
                System.debug('Mapped Application_Number__c: ' + lead.Application_Number__c);
            } else if (lead.Registration_Number__c != null) {
                // Fallback to Registration Number if Application Number is not available
                opportunity.Application_Number__c = lead.Registration_Number__c;
                System.debug('Mapped Application_Number__c (from Registration Number): ' + lead.Registration_Number__c);
            }
            
            // 5. Map Organisation / Institute Name
            if (lead.Organisation_Institute_Name__c != null) {
                opportunity.Organisation_Institute_Name__c = lead.Organisation_Institute_Name__c;
                System.debug('Mapped Organisation_Institute_Name__c: ' + lead.Organisation_Institute_Name__c);
            } else if (lead.Company != null) {
                // Fallback to Company if Organisation Institute Name is not available
                opportunity.Organisation_Institute_Name__c = lead.Company;
                System.debug('Mapped Organisation_Institute_Name__c (from Company): ' + lead.Company);
            }
            
            // 6. Map Designation
            if (lead.Designation__c != null) {
                opportunity.Designation__c = lead.Designation__c;
                System.debug('Mapped Designation__c: ' + lead.Designation__c);
            }
            
            // 7. Map Highest Qualification
            if (lead.My_Highest_Qualification__c != null) {
                opportunity.Highest_Qualification__c = lead.My_Highest_Qualification__c;
                System.debug('Mapped My_Highest_Qualification__c: ' + lead.My_Highest_Qualification__c);
            }
            
            // 8. Map Engagement Score
            if (lead.Engagement_Score__c != null) {
                opportunity.Engagement_Score__c = lead.Engagement_Score__c;
                System.debug('Mapped Engagement_Score__c: ' + lead.Engagement_Score__c);
            }
            
            // 9. Map Total Work Experience
            if (lead.Total_Work_Experience_Year_s__c != null) {
                opportunity.Total_Work_Experience_Year_s__c = lead.Total_Work_Experience_Year_s__c;
                System.debug('Mapped Total_Work_Experience_Year_s__c: ' + lead.Total_Work_Experience_Year_s__c);
            }
            
            // Add timestamp for tracking
            opportunity.Auris_Last_Modified_Timestamp__c = System.now().format('yyyy-MM-dd:HH:mm:ss');
            
            System.debug('Executive Education field mapping completed successfully for Opportunity: ' + opportunity.Id);
            
        } catch (Exception e) {
            System.debug('Error in mapExecutiveEducationFields: ' + e.getMessage() + ' | ' + e.getStackTraceString());
            // Don't throw exception to avoid blocking the entire conversion process
            // Just log the error and continue
        }
    }   
    
    
    /**
    * created By - Rishav 
    * @description - Method to map Executive Education specific fields from Lead to Account
    * @param lead - Source Lead record
    * @param account - Target Account record
    */
    public static void mapExecutiveEducationFieldsToAccount(Lead lead, Account account) {
        try {
            System.debug('Starting Executive Education Account field mapping for Lead: ' + lead.Id);
            
            // Check if this is an Executive Education record type
            if (lead.RecordType.DeveloperName != 'Executive_Education' && 
                lead.RecordType.DeveloperName != 'Executive_Education_Lead') {
                System.debug('Not an Executive Education Lead. Skipping Account mapping.');
                return;
            }
            
            // Also check if Account is Executive Education record type
            if (account.RecordType.DeveloperName != 'Executive_Education' && 
                account.RecordType.DeveloperName != 'Executive_Education_Account') {
                System.debug('Account is not Executive Education type. Skipping Account mapping.');
                return;
            }
            
            System.debug('Processing Executive Education Account mapping for Lead: ' + lead.Id);
            
            // Map organisation/institute details
            if (lead.Organisation_Institute_Name__c != null) {
                account.Organisation_Institute_Name__c = lead.Organisation_Institute_Name__c;
            }
            
            
            if (lead.Total_Work_Experience_Year_s__c != null) {
                account.Total_Work_Experience_Year_s__c = lead.Total_Work_Experience_Year_s__c;
            }
            
            System.debug('Executive Education Account field mapping completed for Account: ' + account.Id);
            
        } catch (Exception e) {
            System.debug('Error in mapExecutiveEducationFieldsToAccount: ' + e.getMessage());
            // Continue without throwing
        }
    }    

