    /******************************************************************************************
     * Method Name : updatePhoneWithCountryCode
     * Created By  : Preksha Chauhan
     * Created Date: 07/18/2024
     * Description : This method updates the phone numbers of Lead records with the appropriate 
     *               country dialing code based on the Lead's country. It removes any existing 
     *               country code from the phone number before adding the new country code.
     * Parameters  : 
     *     @param oldLeads (Map<Id, Lead>) - A map of old Lead records.
     *     @param newLeads (List<Lead>) - A list of new Lead records to be updated.
     *******************************************************************************************/
    public static void updatePhoneWithCountryCode(Map<Id, Lead> oldLeads, List<Lead> newLeads, String operation) {
        
        // For Mcube API
        List<User> userList = [SELECT Id, Profile.Name FROM User];
        Map<Id, String> userDataMap = new Map<Id, String>();
        
        for (User singleUser : userList) {
            userDataMap.put(singleUser.Id, singleUser.Profile.Name);
        }
        
        for (Lead lead : newLeads) {
            System.debug('527 ----------' +lead.phone);
            if (lead.Phone != null) {
                String afterRemoveCountryCode = removeExistingCountryCode(lead.Phone);
                System.debug('530 ----------' +lead.phone);
                if (lead.CountryCode == null || lead.CountryCode == 'IN') {
                    // Default to India country code if no country code is provided
                    lead.Phone = generatePhoneNumberWithCountryCode('IN', afterRemoveCountryCode);
                } else {
                    // Handle international country codes
                    lead.Phone = generatePhoneNumberWithCountryCode(lead.CountryCode, afterRemoveCountryCode);
                }
                System.debug('Phone after processing: ' + lead.Phone);
            }
        }
    }

    /******************************************************************************************
     * Method Name : removeExistingCountryCode
     * Created By  : Preksha Chauhan
     * Created Date: 07/18/2024
     * Description : This helper method removes any existing country code from the phone number.
     * Parameters  : 
     *     @param phone (String) - The phone number from which the country code needs to be removed.
     *     @return (String) - The phone number without the country code.
     *******************************************************************************************/
    public static String removeExistingCountryCode(String phone) {
        for (String code : countryCodeMap.values()) {
            if (phone.startsWith(code)) {
                // Remove the existing country code
                return phone.substring(code.length()).trim();
            }
        }
        return phone; // Return unchanged if no country code was found
    }
    
    public static String generatePhoneNumberWithCountryCode(String countryName, String phoneNumber) {
        String newCountryCode = countryCodeMap.get(countryName);
        System.debug('Country Code: ' + newCountryCode + ' Phone Number: ' + phoneNumber);
        String updatePhoneNumber = newCountryCode + phoneNumber.replaceAll('\\D', ''); // Ensure only digits are appended
        return updatePhoneNumber;
    }
